# ============ AriseAi frontend env ============

# Google OAuth Client ID (type: Web application).
VITE_GOOGLE_CLIENT_ID="xxxxxxxx.apps.googleusercontent.com"

# Base URL API. Kosongkan di Vercel jika frontend dan API satu domain.
# Lokal default juga bisa dikosongkan bila Vite proxy diarahkan ke backend.
# VITE_API_BASE=""

# --- Monitoring (Sentry) ---
# Kosongkan jika belum setup Sentry. Error tracking akan disabled.
# VITE_SENTRY_DSN="https://xxxx@o0.ingest.sentry.io/0"
