# =============================================================================
# AriseHash — Environment Variables (Server + Frontend)
# =============================================================================
# Salin file ini ke .env (atau set di Vercel Dashboard):
#   cp .env.example .env
#
# Wajib diisi sebelum menjalankan aplikasi. Variabel tanpa nilai default akan
# membuat aplikasi error/crash jika tidak diset.
#
# 👉 Untuk deploy Vercel, set semua variabel ini di:
#    Settings → Environment Variables (Production & Preview)
# =============================================================================

# ── Database (Postgres / Supabase) ─────────────────────────────────────────
# Pooled URL untuk koneksi runtime (Prisma). Supabase pooler biasanya port 6543.
# Pakai ?sslmode=require.
DATABASE_URL="postgresql://postgres.project-ref:password@aws-1-region.pooler.supabase.com:6543/postgres?sslmode=require"

# Direct URL untuk Prisma push/migrate. Supabase direct biasanya port 5432.
DIRECT_URL="postgresql://postgres.project-ref:password@aws-1-region.pooler.supabase.com:5432/postgres?sslmode=require"

# ── Keamanan & Autentikasi ─────────────────────────────────────────────────
# JWT Secret — WAJIB string acak panjang (min 32 karakter).
#   Linux: openssl rand -base64 48
#   Mac:   openssl rand -base64 48
JWT_SECRET="ganti-dengan-string-acak-min-32-karakter"

# Secret untuk enkripsi API key milik user (AES-256-GCM).
# Jika tidak diset, akan fallback ke JWT_SECRET (tidak direkomendasikan).
AI_KEY_SECRET="ganti-dengan-string-acak-berbeda-dari-jwt"

# Google OAuth Web Client ID — WAJIB.
# Buat di https://console.cloud.google.com/apis/credentials
# Tipe: "OAuth 2.0 Client ID" → "Web application"
# Tambahkan authorized origins:
#   - http://localhost:5173
#   - https://domain-vercel-anda.vercel.app
GOOGLE_CLIENT_ID="123456789012-xxxxxxx.apps.googleusercontent.com"

# Daftar email admin (dipisah koma). User dengan email ini otomatis role ADMIN.
ADMIN_EMAILS="admin@example.com"

# ── CORS & Domain ──────────────────────────────────────────────────────────
# Origin yang diizinkan CORS (dipisah koma). Di Vercel, set ke domain produksi.
CLIENT_ORIGIN="http://localhost:5173,http://127.0.0.1:5173"

# ── AI Gateway (Seed Models untuk AdminAiKey) ──────────────────────────────
# API key untuk seed data AI models. Jalankan setelah set:
#   npm run db:seed
# Hanya model dengan API key yang diset yang akan ditambahkan.
SEED_MIMO_KEY="sk-..."       # MiMo 2.5 (api.xiaomimimo.com)
SEED_UPBIT_KEY="sk-..."      # Upbit Gateway (gateway.upbit.my.id)
SEED_QWEN_KEY="sk-..."       # Qwen (dashscope-intl.aliyuncs.com)
SEED_BYNARA_KEY="sk-..."     # Bynara Router (router.bynara.id)

# ── Email (Resend) ─────────────────────────────────────────────────────────
# API key Resend untuk email welcome, undangan kolaborasi, peringatan kuota.
# Jika kosong, semua email akan di-skip (log ke console).
RESEND_API_KEY="re_..."

# Alamat email pengirim. Default: AriseHash <onboarding@resend.dev>
EMAIL_FROM="AriseHash <noreply@domain-anda.com>"

# ── Error Tracking (Sentry) ────────────────────────────────────────────────
# DSN untuk Sentry error tracking. Opsional — jika kosong, Sentry tidak diinit.
SENTRY_DSN="https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@xxxxxxxxx.ingest.us.sentry.io/1234567"

# ── Server ─────────────────────────────────────────────────────────────────
# Port server (default 4000). Di Vercel tidak perlu diset.
PORT=4000

# Node environment. Vercel otomatis set NODE_ENV=production saat deploy.
NODE_ENV="development"

# ── Legacy AI Keys (Health Check) ───────────────────────────────────────────
# Digunakan hanya untuk endpoint /api/health — mengecek konfigurasi.
# Seed models via admin AI keys adalah metode utama.
AI_STANDARD_KEY="sk-..."
AI_MAX_KEY="sk-..."

# =============================================================================
# Frontend (Vite) — Semua diawali VITE_
# =============================================================================
# Google OAuth Client ID untuk frontend (sama dengan GOOGLE_CLIENT_ID di atas).
VITE_GOOGLE_CLIENT_ID="123456789012-xxxxxxx.apps.googleusercontent.com"

# Base URL API backend. Kosong = pakai proxy Vite (/api) saat lokal.
# Di Vercel, biarkan kosong karena /api di-rewrite ke serverless function.
VITE_API_BASE=""

# DSN Sentry untuk frontend (bisa berbeda dengan server).
VITE_SENTRY_DSN="https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@xxxxxxxxx.ingest.us.sentry.io/1234567"
