# ============ AriseAi server env ============

# --- Database: Supabase/Postgres ---
# Runtime pooled URL, biasanya port 6543.
DATABASE_URL="postgresql://postgres.project-ref:PASSWORD@aws-1-region.pooler.supabase.com:6543/postgres?sslmode=require"
# Direct URL untuk Prisma push/migrate, biasanya port 5432.
DIRECT_URL="postgresql://postgres.project-ref:PASSWORD@aws-1-region.pooler.supabase.com:5432/postgres?sslmode=require"

# --- Security ---
# Required in production.
JWT_SECRET="ganti-dengan-string-acak-panjang"
# Required for encrypting user-supplied AI API keys (BYOK).
AI_KEY_SECRET="ganti-dengan-string-acak-panjang-berbeda"

# --- Google OAuth ---
GOOGLE_CLIENT_ID="xxxxxxxx.apps.googleusercontent.com"
ADMIN_EMAILS="admin@example.com"

# --- CORS ---
# Local default: http://localhost:5173,http://127.0.0.1:5173
# Production example: https://ariseai.vercel.app
CLIENT_ORIGIN="http://localhost:5173,http://127.0.0.1:5173"

# --- AI Gateway: Standard Thinking ---
AI_STANDARD_BASE="https://api.tokenrouter.com/v1"
AI_STANDARD_KEY="sk-xxxx-tokenrouter"
AI_STANDARD_MODELS="MiniMax-M3"

# --- AI Gateway: Max Thinking ---
AI_MAX_BASE="https://provider.example.com/v1"
AI_MAX_KEY="sk-xxxx-provider"
AI_MAX_MODELS="claude-opus-stable"

# --- Email (Resend) ---
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY="re_xxxx"
EMAIL_FROM="AriseAi <noreply@ariseai.com>"

# --- Monitoring (Sentry) ---
# Get your DSN at https://sentry.io
SENTRY_DSN="https://xxxx@o0.ingest.sentry.io/0"
