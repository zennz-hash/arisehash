{
  "name": "arisehash-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --import ./src/sentry.js --watch src/index.js",
    "start": "node --import ./src/sentry.js src/index.js",
    "test": "node --test test/*.test.js",
    "db:validate": "prisma validate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "db:studio": "prisma studio",
    "db:seed": "node src/utils/seed-models.js"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@sentry/node": "^10.59.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^8.5.2",
    "google-auth-library": "^9.14.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.2.0",
    "resend": "^6.14.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "prisma": "^5.22.0"
  }
}
